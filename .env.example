# 百灵中枢环境变量示例
# 本地开发可以只用 config.example.json；生产部署请设置 BAILING_ENV=production，
# 并把 token、数据库口令、模型 key、webhook 地址等敏感项全部放在环境变量或密钥管理器里。

# BAILING_ENV=production
# BAILING_HOST=127.0.0.1
# BAILING_PORT=18900
# BAILING_TOKEN=replace-with-a-long-random-secret

# Docker demo 对外端口。直接 docker compose up 不配也会使用这些默认值。
# BAILING_PUBLIC_PORT=18900
# BAILING_DEMO_PUBLIC_PORT=19080
# BAILING_MYSQL_PUBLIC_PORT=3307

# 一键安装模式：image=使用官方预构建镜像；source=下载源码后本机构建。
# BAILING_INSTALL_MODE=image
# BAILING_SKIP_PORT_CHECK=0
# BAILING_ALLOW_UNTESTED_ARCH=0
# BAILING_IMAGE_REGISTRY=crpi-xm97pbcjrmf5in3s.cn-shanghai.personal.cr.aliyuncs.com
# BAILING_IMAGE_NAMESPACE=bailinghub
# BAILING_IMAGE_TAG=0.1.0
# BAILINGHUB_IMAGE=crpi-xm97pbcjrmf5in3s.cn-shanghai.personal.cr.aliyuncs.com/bailinghub/bailinghub:0.1.0
# BAILING_DEMO_BUSINESS_IMAGE=crpi-xm97pbcjrmf5in3s.cn-shanghai.personal.cr.aliyuncs.com/bailinghub/bailing-demo-business:0.1.0
# BAILING_MYSQL_IMAGE=crpi-xm97pbcjrmf5in3s.cn-shanghai.personal.cr.aliyuncs.com/bailinghub/bailing-mysql:8.4
# BAILING_NODE_IMAGE=node:22-bookworm-slim

# 状态库：完整能力建议使用 mysql。
# BAILING_STATE_BACKEND=mysql
# BAILING_MYSQL_HOST=
# BAILING_MYSQL_PORT=3306
# BAILING_MYSQL_DATABASE=bailinghub
# BAILING_MYSQL_USER=
# BAILING_MYSQL_PASSWORD=
# BAILING_MYSQL_CONNECTION_LIMIT=15
# BAILING_JSON_BODY_MAX_BYTES=1048576
# BAILING_SHUTDOWN_DRAIN_MS=30000
# bz_audit 自动保留期，0=不自动删除；生产建议按合规要求设置 90/180/365。
# BAILING_AUDIT_RETENTION_DAYS=0

# Docker demo 内置 MySQL 与 demo 业务系统密钥。一键安装脚本会自动生成强随机值。
# BAILING_DEMO_ADMIN_PASSWORD=bailing-demo-admin
# BAILING_DEMO_MYSQL_ROOT_PASSWORD=bailing-root-pass
# BAILING_DEMO_MYSQL_DATABASE=bailinghub
# BAILING_DEMO_MYSQL_USER=bailing
# BAILING_DEMO_MYSQL_PASSWORD=bailing-pass
# DEMO_TOOL_SECRET=demo-tool-secret-change-me
# DEMO_CLIENT_TOKEN=bailing-demo-client-token

# 展示时区。
# BAILING_DISPLAY_TZ=Asia/Shanghai
# BAILING_DISPLAY_TZ_LABEL=北京时间

# llm 凭证，JSON 对象，key 为凭证名。
# BAILING_LLM_CREDENTIALS_JSON={"deepseek":{"base_url":"https://api.deepseek.com","api_key":"replace-me"}}

# 自监控告警。type=webhook 时直发 URL；其他 type 走同名 notify 执行器目标。
# BAILING_ALERTS_TYPE=webhook
# BAILING_ALERTS_TO=
# BAILING_ALERTS_URL=
# BAILING_ALERTS_COOLDOWN_MIN=60

# 本地执行器进程读取；hub server 进程可不配。
# BAILING_HUB_URL=https://your-hub.example.com
# BAILING_EXECUTOR_TOKEN=
# BAILING_EXECUTOR_ID=worker-01
# BAILING_EXECUTOR_CONCURRENCY=1
