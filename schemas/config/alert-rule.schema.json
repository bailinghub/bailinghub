{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.bailinghub.com/schemas/config/alert-rule.schema.json",
  "title": "Bailing Alert Rule Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["channel", "recipients", "cooldown_min", "enabled"],
  "properties": {
    "id": { "type": "integer", "minimum": 1 },
    "event_prefix": { "type": "string", "maxLength": 64 },
    "channel": { "$ref": "common.schema.json#/$defs/resourceName" },
    "recipients": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "cooldown_min": { "type": "integer", "minimum": 1, "maximum": 1440 },
    "enabled": { "type": "boolean" },
    "description": { "type": "string", "maxLength": 255 }
  }
}
