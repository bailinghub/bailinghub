{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.bailinghub.com/schemas/agent-capability-contract.v1.schema.json",
  "title": "Agent Capability Contract v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "enabled", "scope"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "enabled": { "type": "boolean" },
    "scope": { "type": "string", "minLength": 1, "maxLength": 191 },
    "subject": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "required": { "type": "boolean" }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "level": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "required": { "type": "boolean" },
        "prompt": { "type": "string", "maxLength": 200 },
        "when": {
          "type": "array",
          "maxItems": 20,
          "items": { "$ref": "#/$defs/approvalWhen" }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "readonly": { "type": "boolean" },
        "idempotent": { "type": "boolean" },
        "timeout_ms": { "type": "integer", "minimum": 1, "maximum": 600000 },
        "rate_limit": { "$ref": "#/$defs/rateLimit" }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sensitive": { "type": "boolean" }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "result": { "type": "string", "minLength": 1, "maxLength": 300 },
        "side_effect": { "type": "string", "enum": ["none", "read", "write", "notify", "external"] }
      }
    },
    "guidance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "when_to_use": { "type": "string", "maxLength": 500 },
        "returns": { "type": "string", "maxLength": 500 },
        "examples": {
          "type": "array",
          "maxItems": 5
        },
        "context": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    }
  },
  "$defs": {
    "rateLimit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "window"],
      "properties": {
        "count": { "type": "integer", "minimum": 1 },
        "window": { "type": "string", "enum": ["1s", "1m", "1h", "1d"] }
      }
    },
    "approvalWhen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["param", "op"],
      "properties": {
        "param": { "type": "string", "minLength": 1, "maxLength": 191 },
        "op": { "type": "string", "enum": [">", ">=", "<", "<=", "==", "!=", "in", "contains", "exists"] },
        "value": true,
        "label": { "type": "string", "minLength": 1, "maxLength": 120 }
      }
    }
  }
}
